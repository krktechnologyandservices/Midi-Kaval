{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=kaval_dev;Username=kaval;Password=kaval_dev",
    "Redis": "localhost:6379"
  },
  "Jwt": {
    "Issuer": "MidiKaval",
    "Audience": "MidiKaval",
    "AccessTokenMinutes": 15
  },
  "Otp": {
    "ExpiryMinutes": 5,
    "MaxAttempts": 5
  },
  "Totp": {
    "Issuer": "Midi-Kaval",
    "StepSeconds": 30,
    "CodeLength": 6
  },
  "RefreshToken": {
    "ExpiryDays": 7
  },
  "Auth": {
    "RateLimitPermitLimit": 10,
    "RateLimitWindowSeconds": 60
  },
  "DataRateLimiting": {
    "ReadPermitLimit": 100,
    "WritePermitLimit": 20,
    "WindowSeconds": 60
  },
  "AuditDigestJob": {
    "WindowMinutes": 5,
    "IntervalMinutes": 5
  },
  "CaseAnonymizationJob": {
    "RetentionYears": 7,
    "BatchSize": 100,
    "IntervalHours": 24
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200" ]
  },
  "CaseExport": {
    "MaxRows": 5000
  },
  "B2Storage": {
    "BucketName": "attachments-midi-kaval",
    "MaxUploadBytes": 10485760
  },
  "ACTIVATION_TOKEN_TTL_HOURS": 168,
  "ActivationLink": {
    "BaseUrl": "http://localhost:4200"
  },
  "INVITATION_TOKEN_TTL_HOURS": 24,
  "ConfirmationLink": {
    "BaseUrl": "http://localhost:4200",
    "TokenTtlHours": 24
  },
  "DualAuth": {
    "Enabled": true
  }
}
