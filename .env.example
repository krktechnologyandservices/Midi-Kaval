# Copy this file to ".env" on the VM (never commit the real ".env") and fill in the
# placeholders. Values already filled in below were freshly generated for this
# deployment specifically — they are NOT the same secrets used on Render, so a leak
# in one environment doesn't compromise the other.

# Your DuckDNS (or real) domain, e.g. midi-kaval.duckdns.org — Caddy uses this both to
# request a Let's Encrypt certificate and to build the CORS/link URLs below.
SITE_DOMAIN=

POSTGRES_PASSWORD=KbiBYX6VIsVzknyMrOIEtqJ4fOWXCHny
REDIS_PASSWORD=gRdfVi1dhjrUaHng7kv86J6rV7N2l0m

JWT_SIGNING_KEY=q3LosQbiCOTrvUjqDjNGrAR7Iho8M1fFkwmadQcUyRf4gMC2yr9pMZKtBCJJ3Bg
ACTIVATION_LINK_SIGNING_KEY=ACKywe81FyMUp7tUFLoLLBIn0jztzKs5NhrBxIfTTan52LgOu2Mte5mYyP4WuhT
# Must be a base64-encoded 32-byte (256-bit) key — the app hard-validates this exact
# length on startup. Generate a new one with `openssl rand -base64 32` if you'd rather
# not reuse this value.
ENCRYPTION_MASTER_KEY=guXQVYXOm5LDAyAJJQAA6g60uovyWaFsp+yUOj9MHds=

# Bootstraps the first Director account on first startup only (no-op afterwards).
SEED_ORGANISATION_ID=467e2ed6-46dc-446f-99cb-a52dd738c29d
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Bootstraps the first Vendor account on first startup only (no-op afterwards).
SEED_VENDOR_EMAIL=karthik.k.82@outlook.com
SEED_VENDOR_PASSWORD=Rivisha1407@

# Backblaze B2 — same bucket already in use for the Render deployment; reuse these
# values, or create a separate bucket if you want the two deployments fully isolated.
B2_REGION=us-east-005
B2_ACCESS_KEY_ID=005512bf62f2a740000000001
B2_SECRET_ACCESS_KEY=K005i4tnV3iWUTh6nObQNfrE6MGkDdM
B2_BUCKET_NAME=attachments-midi-kaval

# EMAIL_PROVIDER switches between "Smtp" and "Brevo". A full VM has normal outbound
# network access (unlike Render's free tier where SMTP appeared blocked), so plain
# Gmail SMTP is used here — same credentials already verified working elsewhere.
EMAIL_PROVIDER=Smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=krktechnologyandservice@gmail.com
SMTP_PASSWORD=hjdaikodpxueawlg
SMTP_FROM=krktechnologyandservice@gmail.com

# Only needed if EMAIL_PROVIDER=Brevo instead — dashboard.brevo.com -> SMTP & API ->
# API Keys, and Senders, Domains & Dedicated IPs -> Senders for the verified sender email.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
